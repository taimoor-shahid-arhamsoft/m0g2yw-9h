{%- if section.blocks.size > 0 -%}

<style>
  #shopify-section-{{ section.id }} .j-featured {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 2 }}, 1fr);
    font-family: var(--font-body-family, 'Helvetica Neue', Arial, sans-serif);
  }
  #shopify-section-{{ section.id }} .j-featured__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: #1a1a1a;
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .j-featured__item img,
  #shopify-section-{{ section.id }} .j-featured__item .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  #shopify-section-{{ section.id }} .j-featured__item:hover img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .j-featured__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 50%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px 36px 40px;
  }
  #shopify-section-{{ section.id }} .j-featured__name {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 4px;
  }
  #shopify-section-{{ section.id }} .j-featured__sub {
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 14px;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .j-featured__cta {
    font-size: 8.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #fff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline-block;
  }
  #shopify-section-{{ section.id }} .j-featured__cta:hover { opacity: 0.75; }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .j-featured { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .j-featured__item { aspect-ratio: 16/9; }
  }
</style>

<div class="j-featured">
  {%- for block in section.blocks -%}
    <a
      href="{{ block.settings.link | default: '/collections/all' }}"
      class="j-featured__item"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image != blank -%}
        {{
          block.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            alt: block.settings.name,
            widths: '450, 750, 900',
            sizes: '50vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      <div class="j-featured__overlay">
        {%- if block.settings.name != blank -%}
          <p class="j-featured__name">{{ block.settings.name }}</p>
        {%- endif -%}
        {%- if block.settings.subtitle != blank -%}
          <p class="j-featured__sub">{{ block.settings.subtitle }}</p>
        {%- endif -%}
        <span class="j-featured__cta">SHOP NOW</span>
      </div>
    </a>
  {%- endfor -%}
</div>

{%- endif -%}

{% schema %}
{
  "name": "J. Featured Collections",
  "tag": "section",
  "class": "j-section-featured",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "item",
      "name": "Collection",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Collection name",
          "default": "AUTOGRAPH SERIES"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "FEATURED COLLECTION"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "J. Featured Collections",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "name": "AUTOGRAPH SERIES",
            "subtitle": "FEATURED COLLECTION"
          }
        },
        {
          "type": "item",
          "settings": {
            "name": "CEREMONIAL",
            "subtitle": "FEATURED COLLECTION"
          }
        }
      ]
    }
  ]
}
{% endschema %}
