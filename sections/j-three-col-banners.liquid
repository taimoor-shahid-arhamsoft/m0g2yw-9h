{%- if section.blocks.size > 0 -%}

<style>
  #shopify-section-{{ section.id }} .j-three-col {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 3 }}, 1fr);
    font-family: var(--font-body-family, 'Helvetica Neue', Arial, sans-serif);
  }
  #shopify-section-{{ section.id }} .j-three-col__item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: #1a1a1a;
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .j-three-col__item img,
  #shopify-section-{{ section.id }} .j-three-col__item .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  #shopify-section-{{ section.id }} .j-three-col__item:hover img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .j-three-col__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 45%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 28px 28px 32px;
  }
  #shopify-section-{{ section.id }} .j-three-col__title {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .j-three-col__cta {
    font-size: 8.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #fff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline-block;
  }
  #shopify-section-{{ section.id }} .j-three-col__cta:hover { opacity: 0.75; }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .j-three-col { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .j-three-col__item { aspect-ratio: 16/9; }
  }
</style>

<div class="j-three-col">
  {%- for block in section.blocks -%}
    <a
      href="{{ block.settings.link | default: '/collections/all' }}"
      class="j-three-col__item"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image != blank -%}
        {{
          block.settings.image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            alt: block.settings.title,
            widths: '300, 450, 600',
            sizes: '33vw'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      <div class="j-three-col__overlay">
        {%- if block.settings.title != blank -%}
          <p class="j-three-col__title">{{ block.settings.title }}</p>
        {%- endif -%}
        <span class="j-three-col__cta">SHOP NOW</span>
      </div>
    </a>
  {%- endfor -%}
</div>

{%- endif -%}

{% schema %}
{
  "name": "J. Three-Col Banners",
  "tag": "section",
  "class": "j-section-three-col",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "item",
      "name": "Banner",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HERITAGE EDIT '26"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "J. Three-Col Banners",
      "blocks": [
        { "type": "item", "settings": { "title": "HERITAGE EDIT '26" } },
        { "type": "item", "settings": { "title": "EXPRESSION SERIES" } },
        { "type": "item", "settings": { "title": "LIKE FATHER LIKE SON" } }
      ]
    }
  ]
}
{% endschema %}
