{%- assign img = section.settings.hero_image -%}
{%- assign h = section.settings.height | default: 580 -%}

<style>
  #shopify-section-{{ section.id }} .j-hero {
    position: relative;
    width: 100%;
    height: {{ h }}px;
    overflow: hidden;
    background: #2b2b2b;
    font-family: var(--font-body-family, 'Helvetica Neue', Arial, sans-serif);
  }
  #shopify-section-{{ section.id }} .j-hero img,
  #shopify-section-{{ section.id }} .j-hero .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: 100% 100%;
    display: block;
  }
  #shopify-section-{{ section.id }} .j-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 55%);
  }
  #shopify-section-{{ section.id }} .j-hero__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .j-hero__content {
    position: absolute;
    bottom: 48px;
    left: 48px;
    color: #fff;
    z-index: 2;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .j-hero__heading {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: 6px;
    text-transform: uppercase;
    margin: 0;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .j-hero__subheading {
    font-size: 18px;
    letter-spacing: 8px;
    text-transform: uppercase;
    font-weight: 300;
    margin: 4px 0 0;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .j-hero { height: calc({{ h }}px * 0.65); }
    #shopify-section-{{ section.id }} .j-hero__content { bottom: 28px; left: 24px; }
    #shopify-section-{{ section.id }} .j-hero__heading { font-size: 22px; }
    #shopify-section-{{ section.id }} .j-hero__subheading { font-size: 12px; }
  }
</style>

<div class="j-hero">
  {%- if img != blank -%}
    {{
      img
      | image_url: width: 1800
      | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.heading,
        widths: '750, 1100, 1500, 1800',
        sizes: '100vw'
    }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
  {%- endif -%}

  <div class="j-hero__overlay" aria-hidden="true"></div>

  {%- if section.settings.button_link != blank -%}
    <a href="{{ section.settings.button_link }}" class="j-hero__link" tabindex="-1" aria-hidden="true"></a>
  {%- endif -%}

  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="j-hero__content">
      {%- if section.settings.heading != blank -%}
        <p class="j-hero__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="j-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "J. Hero Banner",
  "tag": "section",
  "class": "j-section-hero",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "HERITAGE",
      "info": "Large bold uppercase text"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Banner link",
      "info": "Makes the entire banner clickable"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 580
    }
  ],
  "presets": [
    {
      "name": "J. Hero Banner"
    }
  ]
}
{% endschema %}
