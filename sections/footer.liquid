{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'j-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">

  {%- comment -%} ── Main columns ────────────────────────────── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="j-footer__main page-width">

      {%- comment -%} Left columns: every block except newsletter {%- endcomment -%}
      <div class="j-footer__left-cols">
        {%- for block in section.blocks -%}
          {%- if block.type == 'newsletter' -%}
            {%- continue -%}
          {%- endif -%}

          <div
            class="j-footer__col{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="j-footer__heading">{{- block.settings.heading -}}</h2>
            {%- endif -%}

            {%- case block.type -%}

              {%- when '@app' -%}
                {% render block %}

              {%- when 'contact' -%}
                <div class="j-footer__contact">
                  {%- if block.settings.phone != blank -%}
                    <div class="j-footer__contact-item">
                      <span class="j-footer__contact-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.38 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                      </span>
                      <span>{{ block.settings.phone }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.hours != blank -%}
                    <div class="j-footer__contact-item j-footer__contact-item--hours">
                      <span>{{ block.settings.hours }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.email != blank -%}
                    <div class="j-footer__contact-item">
                      <span class="j-footer__contact-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="2" y="4" width="20" height="16" rx="2"/>
                          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                        </svg>
                      </span>
                      <a href="mailto:{{ block.settings.email | escape }}" class="j-footer__contact-link">
                        {{- block.settings.email | escape -}}
                      </a>
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'link_list' -%}
                {%- comment -%}
                  Prefer a Shopify navigation menu if assigned;
                  fall back to the inline link settings on the block.
                {%- endcomment -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="j-footer__links">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a
                          href="{{ link.url }}"
                          class="j-footer__link{% if link.active %} j-footer__link--active{% endif %}"
                        >
                          {{- link.title | escape -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  {%- liquid
                    assign link_labels = block.settings.link_1_label | append: '||' | append: block.settings.link_2_label | append: '||' | append: block.settings.link_3_label | append: '||' | append: block.settings.link_4_label | append: '||' | append: block.settings.link_5_label | append: '||' | append: block.settings.link_6_label | append: '||' | append: block.settings.link_7_label | append: '||' | append: block.settings.link_8_label
                    assign link_urls   = block.settings.link_1_url   | append: '||' | append: block.settings.link_2_url   | append: '||' | append: block.settings.link_3_url   | append: '||' | append: block.settings.link_4_url   | append: '||' | append: block.settings.link_5_url   | append: '||' | append: block.settings.link_6_url   | append: '||' | append: block.settings.link_7_url   | append: '||' | append: block.settings.link_8_url
                    assign labels_arr  = link_labels | split: '||'
                    assign urls_arr    = link_urls   | split: '||'
                  -%}
                  <ul class="j-footer__links">
                    {%- for label in labels_arr -%}
                      {%- if label != blank -%}
                        <li>
                          <a
                            href="{{ urls_arr[forloop.index0] | default: '#' }}"
                            class="j-footer__link"
                          >
                            {{- label | escape -}}
                          </a>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'text' -%}
                <div class="j-footer__text rte">{{ block.settings.subtext }}</div>

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} Right column: newsletter block {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'newsletter' -%}
          <div
            class="j-footer__newsletter-col{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="j-footer__heading">{{- block.settings.heading -}}</h2>
            {%- endif -%}

            {%- form 'customer', id: 'ContactFooter', class: 'j-footer__newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="j-footer__newsletter-field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="j-footer__newsletter-input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooter-success"
                  {% endif %}
                  placeholder="{{ 'newsletter.label' | t | upcase }}"
                  required
                >
                <button
                  type="submit"
                  class="j-footer__newsletter-btn"
                  name="commit"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>

              {%- if form.errors -%}
                <small class="j-footer__form-error" id="ContactFooter-error">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <p class="j-footer__form-success" id="ContactFooter-success" tabindex="-1" autofocus>
                  {{- 'newsletter.success' | t -}}
                </p>
              {%- endif -%}
            {%- endform -%}

            {%- if block.settings.subtext != blank -%}
              <div class="j-footer__newsletter-subtext rte">{{ block.settings.subtext }}</div>
            {%- endif -%}

            {%- if block.settings.show_payment and shop.enabled_payment_types != empty -%}
              <div class="j-footer__payment">
                <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
                <ul class="list-payment" role="list">
                  {%- for type in shop.enabled_payment_types -%}
                    <li class="list-payment__item">
                      {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </div>
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

    </div>
  {%- endif -%}

  {%- comment -%} ── Bottom bar ──────────────────────────────── {%- endcomment -%}
  <div class="j-footer__bottom">
    <div class="j-footer__bottom-wrapper page-width">

      <div class="j-footer__policies">
        {%- if section.settings.show_policy -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <a href="{{ policy.url }}" class="j-footer__policy-link">
                {{- policy.title | upcase | escape -}}
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="j-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }},
        {{ 'J.' | link_to: routes.root_url }}.
        All Rights Reserved
      </div>

    </div>
  </div>

</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "contact",
      "name": "Contact info",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone number",
          "default": "+92 2137 170 445"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Business hours",
          "default": "(MON - SAT: 9:30AM - 10:00PM | SUN : 11AM - 8PM)"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email address",
          "default": "eshop@example.com"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link column",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Column heading",
          "default": "Links"
        },
        {
          "type": "header",
          "content": "Links"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 text"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 text"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 text"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 text"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_label",
          "label": "Link 5 text"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        },
        {
          "type": "text",
          "id": "link_6_label",
          "label": "Link 6 text"
        },
        {
          "type": "url",
          "id": "link_6_url",
          "label": "Link 6 URL"
        },
        {
          "type": "text",
          "id": "link_7_label",
          "label": "Link 7 text"
        },
        {
          "type": "url",
          "id": "link_7_url",
          "label": "Link 7 URL"
        },
        {
          "type": "text",
          "id": "link_8_label",
          "label": "Link 8 text"
        },
        {
          "type": "url",
          "id": "link_8_url",
          "label": "Link 8 URL"
        },
        {
          "type": "header",
          "content": "Or use a navigation menu"
        },
        {
          "type": "paragraph",
          "content": "Assign a Shopify navigation menu to use instead of the links above."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Navigation menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter signup",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Sign Up For Our Newsletter"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Subtext below form",
          "default": "<p>By providing your email, you agree to receive marketing emails and accept our <a href=\"/policies/privacy-policy\">Privacy Policy</a> and <a href=\"/policies/terms-of-service\">Terms</a>.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_payment",
          "label": "Show payment icons",
          "default": true
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label",
      "info": "t:sections.footer.settings.show_policy.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "default": {
    "blocks": [
      { "type": "contact" },
      { "type": "link_list" },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
