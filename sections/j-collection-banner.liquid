{%- assign img = section.settings.image -%}
{%- assign h = section.settings.height | default: 520 -%}

<style>
  #shopify-section-{{ section.id }} .j-col-banner {
    position: relative;
    width: 100%;
    height: {{ h }}px;
    overflow: hidden;
    background: #1a1a1a;
    font-family: var(--font-body-family, 'Helvetica Neue', Arial, sans-serif);
  }
  #shopify-section-{{ section.id }} .j-col-banner img,
  #shopify-section-{{ section.id }} .j-col-banner .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: fill;
    display: block;
  }
  #shopify-section-{{ section.id }} .j-col-banner__heading {
    font-size: clamp(52px, 10vw, 120px);
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .j-col-banner__subheading {
    font-size: clamp(12px, 2vw, 18px);
    letter-spacing: 12px;
    text-transform: uppercase;
    color: #fff;
    font-weight: 300;
    margin: 8px 0 0;
  }
</style>

<div class="j-col-banner">
  {%- if img != blank -%}
    {{
      img
      | image_url: width: 1800
      | image_tag:
        loading: 'lazy',
        alt: section.settings.heading,
        widths: '750, 1100, 1500, 1800',
        sizes: '100vw'
    }}
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
  {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="j-col-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="j-col-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

  {%- if section.settings.link != blank -%}
    </a>
  {%- else -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "J. Collection Banner",
  "tag": "section",
  "class": "j-section-col-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Large heading",
      "default": "MONOCHROME",
      "info": "Big centered text over the image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "COLLECTION"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner link"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 300,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 520
    }
  ],
  "presets": [
    {
      "name": "J. Collection Banner"
    }
  ]
}
{% endschema %}
